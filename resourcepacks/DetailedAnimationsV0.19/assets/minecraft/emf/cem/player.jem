{
	"credit": "",
	"textureSize": [64, 64],
	"models": [
		{
			"part": "cloak",
			"id": "cloak",
			"invertAxis": "xy",
			"translate": [0, -24, 0],
			"boxes": [
				{
					"coordinates": [-5, 8, -1, 10, 16, 1],
					"uvNorth": [1, 2, 11, 34],
					"uvEast": [0, 2, 1, 34],
					"uvSouth": [12, 2, 22, 34],
					"uvWest": [11, 2, 12, 34],
					"uvUp": [11, 2, 1, 0],
					"uvDown": [21, 0, 11, 2]
				}
			],
			"animations": [
				{
					"var.NewFrame": "if(var.LastFrameCount == frame_counter, 0, 1) * if(is_paused, 0, 1)",
					"var.Age": "if(var.NewFrame > 0, age, var.LastAge)",
					"var.AD": "(var.Age - var.LastAge)",
					"var.TD": "frame_time * 60 * var.NewFrame",
					"var.Counter": "var.Counter + var.NewFrame",
					"var.DT": "clamp(var.TD * if(var.TD > 4, 0, 1),0.00000000001,10)",
					"var.PDT": "var.DT",
					"var.PosY": "if(var.NewFrame > 0, pos_y, var.PosY)",
					"var.PosZ": "if(var.NewFrame > 0, pos_z, var.PosZ)",
					"var.PosX": "if(var.NewFrame > 0, pos_x, var.PosX)",
					"var.RotY": "if(var.NewFrame > 0, rot_y, var.RotY)",
					"var.RotX": "if(var.NewFrame > 0, rot_x, var.RotX)",
					"var.HeightAboveGround": "if(var.NewFrame > 0, height_above_ground, var.HeightAboveGround)",
					"var.is_on_ground": "if(is_on_ground, 1, 0)",
					"var.is_riding": "if(is_riding, 1, 0)",
					"var.Speed": "if(var.NewFrame > 0, sqrt((var.LastPosX - var.PosX) * (var.LastPosX - var.PosX) + (var.LastPosZ - var.PosZ) * (var.LastPosZ - var.PosZ)) / var.DT, var.Speed)",
					"var.DistanceMoved": "if(var.NewFrame > 0, var.DistanceMoved + var.Speed * var.DT, var.DistanceMoved)",
					"var.AvgSpeed": "var.AvgSpeed + (var.Speed - var.AvgSpeed) / 2 * var.DT",
					"var.move_direction_y": "atan((var.LastPosX - var.PosX)/(var.LastPosZ - var.PosZ)) + if((var.LastPosZ - var.PosZ) < 0, 180, 0)",
					"var.move_forward": "var.move_forward + (move_forward - var.move_forward) / 5 * var.DT",
					"var.move_strafing": "var.move_strafing + (move_strafing - var.move_strafing) / 5 * var.DT",
					"var.Forward": "if(move_forward < 0, -1, if(move_forward > 0, 1, var.Forward)) + if(var.Forward == 0, 1, 0)",
					"var.Strafing": "if(move_strafing < 0, -1, if(move_strafing > 0, 1, var.Strafing))",
					"var.SwingProgress": "if(var.NewFrame > 0, swing_progress, var.SwingProgress)",
					"var.VelocityY": "if(var.NewFrame > 0, (var.LastPosY - var.PosY) / var.DT, var.VelocityY)",
					"var.AvgVelocityY": "var.AvgVelocityY + (var.VelocityY - var.AvgVelocityY) / 4 * var.DT",
					"var.VelocityYDifference": "(var.LastVelocityY - var.VelocityY) / var.DT",
					"var.VelocityYJump": "if(abs(if(var.VelocityY == 0, 0, abs(var.VelocityY) / var.VelocityY)) > 0, if(var.VelocityY == 0, 0, abs(var.VelocityY) / var.VelocityY), var.VelocityYJump)",
					"var.has_jumped": "if(var.VelocityYJump != var.LastVelocityYJump && var.VelocityY < 0 && var.is_on_ground > 0, 1, 0)",
					"var.Jump_Height": "if(var.has_jumped > 0 || age < 1 || var.is_on_ground > 0, var.PosY, var.Jump_Height)",
					"var.is_jumping": "if((pos_y - var.Jump_Height) > 0.1, 1, 0)",
					"var.VelocityHead_Yaw": "if(var.NewFrame > 0, (var.LastHead_Yaw - head_yaw) / var.DT, var.VelocityHead_Yaw)",
					"var.VelocityHead_Pitch": "if(var.NewFrame > 0, (var.LastHead_Pitch - head_pitch) / var.DT, var.VelocityHead_Pitch)",
					"var.VelocityRotY": "if(var.NewFrame > 0, (var.LastRotY - var.RotY) / var.DT, var.VelocityRotY)",
					"var.AvgVelocityRotY": "var.AvgVelocityRotY + (var.VelocityRotY - var.AvgVelocityRotY) / 3 * var.DT",
					"var.RandomEntityOffset": "if(frame_counter < 5, random() * pi * 8.1349, var.RandomEntityOffset)"
				},
				{
					"var.SleepingPose": "if(nbt(SleepingX, exists:true), 1, 0)",
					"var.SleepingPoseStrength": "var.SleepingPoseStrength + (var.SleepingPose - var.SleepingPoseStrength) / 4 * var.DT",
					"var.OnGroundPose": "if(var.is_on_ground > 0, 1, 0)",
					"var.OnGroundPoseStrength": "var.OnGroundPoseStrength + (var.OnGroundPose - var.OnGroundPoseStrength) / 3 * var.DT",
					"var.InWaterPose": "clamp(fluid_depth_up - abs(floor(var.PosY) - var.PosY), 0, 1) * if(fluid_depth_up > 1, 0 + abs(floor(var.PosY) - var.PosY) * if(fluid_depth_up > 2, 0, 1), 1) * (1 - var.SwimPose) + if(var.is_on_ground > 0 && fluid_depth_up > 2, 1, 0)",
					"var.InWaterPoseStrength": "var.InWaterPoseStrength + (var.InWaterPose * (1 - var.BoatRidePose) - var.InWaterPoseStrength) / 8 * var.DT",
					"var.InsideWaterPose": "if((fluid_depth_up - abs(floor(var.PosY) - var.PosY)) > 0.8 && var.OnGroundPose < 1 && var.SwimPose < 1 && var.WalkingStrength < 0.025, 1, 0)",
					"var.InsideWaterPoseStrength": "var.InsideWaterPoseStrength + ((var.InsideWaterPose + clamp(var.VelocityY, -0.1, 0.1) * var.InsideWaterPose * 8) * (1 - var.BoatRidePose) - var.InsideWaterPoseStrength) / 28 * var.DT",
					"var.InsideWaterTimer": "var.InsideWaterTimer + var.DT * 0.02 * var.NewFrame",
					"var.MovingInsideWaterPose": "if((fluid_depth_up - abs(floor(var.PosY) - var.PosY)) > 0.8 && var.OnGroundPose < 1 && var.SwimPose < 1 && var.WalkingStrength > 0.025, 1, 0)",
					"var.MovingInsideWaterPoseStrength": "var.MovingInsideWaterPoseStrength + ((var.MovingInsideWaterPose + clamp(var.VelocityY, -0.1, 0.1) * var.MovingInsideWaterPose * 8) - var.MovingInsideWaterPoseStrength) / 28 * var.DT",
					"var.MovingInsideWaterPoseTimer": "if(var.MovingInsideWaterPoseStrength > 0.05, var.MovingInsideWaterPoseTimer + var.DT * 0.02, 0)",

					"var.FallingPose": "if(var.VelocityY > 0 && var.HopRunPose < 1 && var.ClimbPose < 1 && var.SwimPose < 1 && var.InsideWaterPose < 1, 1, 0)",
					"var.FallPose": "if(var.LastFallingPose < 1 && var.FallingPose > 0, 1, 0)",
					"var.AccidentalFall": "if(abs(var.LastHeightAboveGround - var.HeightAboveGround) > 2 && var.FallPose > 0, 1, if(var.FallingPose < 1, 0, var.AccidentalFall))",
					"var.FallingPoseHeight": "if(var.FallPose > 0, var.HeightAboveGround, var.FallingPoseHeight)",
					"var.FallingPoseTimer": "if(if(var.FallingPose > 0, 1, round(var.NormalFallingPoseStrength * 4) / 4) > 0, var.FallingPoseTimer + var.DT, 0)",
					"var.NormalFallingPose": "if(var.FallingPose > 0 && var.FallingPoseTimer > 15, 1, 0)",
					"var.NormalFallingPoseStrength": "var.NormalFallingPoseStrength + (var.NormalFallingPose - var.NormalFallingPoseStrength) / 8 * var.DT",
					"var.FreeFallingPose": "if(var.FallingPose > 0 && var.FallingPoseHeight > 20, 1, 0)",
					"var.FreeFallingPoseStrength": "var.FreeFallingPoseStrength + (var.FreeFallingPose - var.FreeFallingPoseStrength) / 32 * var.DT",
					"var.TumbleFallPose": "if(var.FreeFallingPose > 0 && var.AccidentalFall > 0, 1, 0)",
					"var.TumbleFallPoseStrength": "var.TumbleFallPoseStrength + (var.TumbleFallPose - var.TumbleFallPoseStrength) / 32 * var.DT",
					"var.HopRunTimer": "if(var.HopRunningPose > 0, var.HopRunTimer, round(var.WalkingTimer / torad(180)) * torad(180) + var.has_jumped * torad(180))",
					"var.HopRunPose": "if(var.is_jumping > 0 && is_sprinting && var.SneakingPose < 1 && var.MovingInsideWaterPose < 1, 1, 0)",
					"var.HopRunPoseStrength": "var.HopRunPoseStrength + (var.HopRunPose - var.HopRunPoseStrength) / 3 * var.DT",
					"var.IdlePose": "if(limb_speed < 0.1, 1, 0) * var.OnGroundPose * (1 - var.CrawlPose) * (1 - var.SleepingPose)",
					"var.IdlePoseStrength": "var.IdlePoseStrength + (var.IdlePose - var.IdlePoseStrength) / 7 * var.DT * var.NewFrame",
					"var.IdlePoseTimer": "if(var.IdlePoseStrength > 0.1, var.IdlePoseTimer + var.DT, 0)",
					"var.IdleTimer": "age + var.RandomEntityOffset * pi",
					"var.IdleRY": "var.IdleRY + (head_yaw * if(var.is_on_ground > 0, 1, 0) - var.IdleRY) / 8 * var.DT * var.NewFrame",
					"var.IdleRX": "var.IdleRX + (head_pitch * if(var.is_on_ground > 0, 1, 0) - var.IdleRX) / 8 * var.DT * var.NewFrame",
					"var.AirPose": "if(var.is_on_ground < 1, 1, 0)",
					"var.AirPoseStrength": "var.AirPoseStrength + (var.AirPose - var.AirPoseStrength) / 7 * var.DT",
					"var.SneakingPose": "if(is_sneaking, 1, 0)",
					"var.SneakingPoseStrength": "var.SneakingPoseStrength + ((var.SneakingPose * (0.25 + var.OnGroundPoseStrength * 0.75)) - var.SneakingPoseStrength) / 2 * var.DT",
					"var.SneakingLegPoseStrength": "var.SneakingLegPoseStrength + (var.SneakingPoseStrength * (1 - clamp(abs(move_forward) + abs(move_strafing), 0, 1)) - var.SneakingLegPoseStrength) / 4 * var.DT",
					"var.SneakingTimer": "if(var.SneakingPoseStrength > 0.1, var.SneakingTimer + var.DT * 3, 0)",
					"var.WalkingTimer": "lerp(1 - var.HopRunPoseStrength, var.WalkingTimer + ((var.HopRunTimer + torad(90) - 0.05) - var.WalkingTimer) / 12 * var.DT, if(var.SneakingPose > 0 && limb_speed < 0.1, var.WalkingTimerAbsolute, var.WalkingTimer + (1 + abs(var.VelocityY) * torad(180)) * var.DT * 0.18 / (1 + var.InWaterPoseStrength * 1) * (1 - var.HopRunningPoseStrength) * (1 + var.SprintPoseStrength * 0.1) * abs(move_forward + 0.1) / (move_forward + 0.1) / (1 + var.SneakingPoseStrength) / (1 + var.MovingInsideWaterPoseStrength)))",
					"var.WalkingRightTimer": "var.WalkingTimer",
					"var.WalkingLeftTimer": "var.WalkingTimer + torad(180)",
					"var.WalkingStrength": "limb_speed * (1 + var.InWaterPoseStrength * 1) * (1 + var.SneakingPoseStrength * var.SprintPoseStrength) * (1 + var.SneakingPoseStrength) * (1 - var.AirPoseStrength * 0.75) * (1 + var.HopRunPoseStrength * 4) * (1 - var.SwimPoseStrength) * (1 + var.MovingInsideWaterPoseStrength) * (1 - var.CrawlPoseStrength) * (1 - var.NormalFallingPoseStrength) * (1 - var.SleepingPoseStrength)",
					"var.WalkingArmStrength": "var.WalkingStrength * (1 + var.InWaterPoseStrength * 0.5) / (1 + var.SneakingPoseStrength) * (1 - var.RightArmCarryStrength) * (1 - var.LeftArmCarryStrength)",
					"var.WalkingTimerAbsolute": "if(limb_speed > 0.2, floor(var.WalkingTimer / torad(180)) * torad(180), var.WalkingTimerAbsolute)",
					"var.SprintPose": "if(is_sprinting && !is_sneaking, 1, 0)",
					"var.SprintPoseStrength": "var.SprintPoseStrength + (var.SprintPose - var.SprintPoseStrength) / 4 * var.DT",
					"var.IdleWatchingPose": "if(var.IdlePose > 0 || var.InsideWaterPose > 0, 1, 0) * (1 - var.SleepingPose) * if(var.SwingPoseTimer < 50, 0, 1)",
					"var.IdleWatchingPoseStrength": "var.IdleWatchingPoseStrength + (var.IdleWatchingPose - var.IdleWatchingPoseStrength) / 32 * var.DT",
					"var.IdleWatchingTimer": "var.IdleTimer",
					"var.IdleWatchingRY": "sin(var.IdleWatchingTimer * 0.1 + sin(var.IdleWatchingTimer * 0.2) * 1) * (0.5 - clamp(cos(var.IdleWatchingTimer * 0.01 + cos(var.IdleWatchingTimer * 0.02) * 4), -1, 1)) * var.IdleWatchingPoseStrength * 0.1",
					"var.IdleWatchingRX": "cos(var.IdleWatchingTimer * 0.05 + cos(var.IdleWatchingTimer * 0.1) * 1) * (0.5 - clamp(sin(var.IdleWatchingTimer * 0.005 + sin(var.IdleWatchingTimer * 0.01) * 4), -1, 1)) * var.IdleWatchingPoseStrength * 0.1",
					"var.HeadTurningPose": "if(abs(var.VelocityHead_Yaw) + abs(var.VelocityHead_Pitch) > 0, 1, 0)",
					"var.HeadTurningPoseStrength": "var.HeadTurningPoseStrength + (var.HeadTurningPose - var.HeadTurningPoseStrength) / 8 * var.DT",
					"var.BoatRidePose": "if(nbt(RootVehicle.Entity.id,raw:iregex:.*\\_boat), 1, 0)",
					"var.BoatRidePoseStrength": "var.BoatRidePoseStrength + (var.BoatRidePose - var.BoatRidePoseStrength) / 4 * var.DT",
					"var.TurnPose": "if(abs(var.VelocityRotY) > 0 && var.WalkingStrength < 0.1 && var.OnGroundPose > 0 && var.CrawlPose < 1, 1, 0)",
					"var.TurnDirection": "if(var.VelocityRotY == 0, 0, abs(var.VelocityRotY) / var.VelocityRotY)",
					"var.TurnTimer": "if(var.TurnPose > 0, var.TurnTimer + var.DT * 3 * abs(var.AvgVelocityRotY), 0)",
					"var.TurnPoseStrength": "var.TurnPoseStrength + (var.TurnPose * clamp(var.TurnTimer, 0, 1) - var.TurnPoseStrength) / 4 * var.DT",
					"var.TurnPoseTimer": "if(var.TurnPoseStrength > 0.01, var.TurnPoseTimer + var.DT * 3 * abs(var.AvgVelocityRotY) * var.TurnDirection, 0)"
				},
				{
					"var.brx": "clamp(var.WalkingStrength, 0, 1) * 0.15 * var.move_forward * (1 - var.SneakingPoseStrength * 0.1) + cos(var.WalkingTimer * 2 - 0.5) * clamp(var.WalkingStrength, 0, 1 - var.SneakPoseStrength * 0.1) * 0.025 * (1 + var.SprintPoseStrength * 0.35) + var.SprintPoseStrength * 0.2 + var.SneakingPoseStrength * 0.7 - var.SneakingLegPoseStrength * 0.1 * (1 + var.WalkingStrength * 0.1) + var.VerticalTotalForce * 1 + sin(var.IdleTimer * 0.1) * var.IdlePoseStrength * 0.025 - var.IdlePoseStrength * 0.01 + var.IdleRX / 240 * var.IdlePoseStrength + var.IdleWatchingRX * 0.5 + sin(var.InsideWaterTimer) * var.InsideWaterPoseStrength * 0.1 - var.InsideWaterPoseStrength * 0.05 - clamp(var.WalkingStrength, 0, 1) * 2 * var.move_forward * var.MovingInsideWaterPoseStrength * 0.2 + abs(var.RightLegTurnStep * 0.05 + var.LeftLegTurnStep * 0.05) * var.LegTurnPoseStrength + var.BoatRidePoseStrength * -0.05 - clamp(var.AvgSpeed, 0, 0.25) * var.BoatRidePoseStrength * 1.75 * var.move_forward + sin(var.TurnPoseTimer * 2) * var.TurnPoseStrength * 0.01 + var.TurnPoseStrength * 0.01",
					"var.bry": "clamp(var.WalkingStrength, 0, 1) * -0.15  * var.move_strafing * (1 - var.SneakingPoseStrength * 0.25) + sin(var.WalkingTimer + sin(var.WalkingTimer * 2) * 0.1) * clamp(var.WalkingStrength, 0, 1 - var.SneakPoseStrength) * 0.2 + sin(var.WalkingTimerAbsolute + cos(var.WalkingTimerAbsolute * 2)) * var.SneakingLegPoseStrength * -0.2 + sin(var.WalkingTimer + cos(var.WalkingTimer * 2) * 0.1) * (var.SneakingPoseStrength - var.SneakingLegPoseStrength) * -0.3 - cos(var.WalkingTimerAbsolute) * var.IdlePoseStrength * 0.05 + var.IdleRY / 240 * var.IdlePoseStrength +  + cos(var.WalkingTimerAbsolute) * clamp(var.IdlePoseTimer * 0.1 - 0.5, 0, 1) * -0.1 * if(var.IdlePose < 1, var.IdlePoseStrength, 1) - sin(var.WalkingLeftTimer - 0.6) * var.MovingInsideWaterPoseStrength * 0.1 + cos(var.TurnPoseTimer + cos(var.TurnPoseTimer * 2) * 0.25) * var.TurnPoseStrength * 0.1",
					"var.brz": "clamp(var.WalkingStrength, 0, 1) * -0.15 * var.move_strafing * (1 - var.SneakingPoseStrength * 0.25) + sin(var.WalkingTimer + sin(var.WalkingTimer) * 0.1) * clamp(var.WalkingStrength, 0, 1 - var.SneakPoseStrength) * -0.02 - var.IdleWatchingRY * 0.2 + var.RightLegTurnStep * 0.01 - var.LeftLegTurnStep * 0.01 + clamp(var.AvgSpeed, 0, 0.1) * var.BoatRidePoseStrength * 1.75 * var.move_strafing",
					"var.btx": "sin(var.IdleTimer * 0.05) * var.IdlePoseStrength * 0.25",
					"var.bty": "abs(sin(var.WalkingTimer + sin(var.WalkingTimer * 2) * 0.1)) * (1 - var.MovingInsideWaterPoseStrength) * clamp(var.WalkingStrength, 0, 1 - var.SneakPoseStrength) * -1.5 + var.WalkingStrength * 0.5 + var.SneakingPoseStrength * 2 + var.SneakingLegPoseStrength * 0.5 + var.SprintPoseStrength * 0.25 + cos(var.IdleTimer * 0.1) * var.IdlePoseStrength * 0.1 + var.BoatRidePoseStrength - cos(var.TurnPoseTimer * 2) * var.TurnPoseStrength * 0.25",
					"var.btz": "var.SneakingPoseStrength * 4 + (var.SneakingPoseStrength - var.SneakingLegPoseStrength) * -0.1 - cos(var.IdleTimer * 0.1) * var.IdlePoseStrength * 0.25 + cos(var.WalkingTimer * 2 - 1) * (var.SneakingPoseStrength * var.WalkingStrength * 0.5)  + (1 - var.SneakingLegPoseStrength) * 1 * var.SneakingPoseStrength + var.IdleRX / 48 * var.IdlePoseStrength"
				},
				{
					"var.llrx": "sin(var.WalkingRightTimer - 0.2) * clamp(var.WalkingStrength, 0, 1 - var.SneakPoseStrength) * 0.85 + clamp(var.WalkingStrength, 0, 1 - var.SneakPoseStrength) * 0.15 + var.SneakingLegPoseStrength * 0.3 * cos(var.WalkingTimerAbsolute) + var.SneakingPoseStrength * 0.2 + var.SprintPoseStrength * var.WalkingStrength * 0.1 + abs(clamp(cos(var.WalkingTimerAbsolute), 0, 1)) * var.IdlePoseStrength * 0.05 + cos(var.IdleTimer * 0.1) * var.IdlePoseStrength * 0.025 + (var.SneakingPoseStrength * 0.2) + (1 - var.SneakingLegPoseStrength) * 0.1 * var.SneakingPoseStrength + abs(clamp(cos(var.WalkingTimerAbsolute), 0, 1)) * clamp(var.IdlePoseTimer * 0.1 - 0.5, 0, 1) * 0.1 * if(var.IdlePose < 1, var.IdlePoseStrength, 1) + sin(var.InsideWaterTimer * 4) * var.InsideWaterPoseStrength * 0.1 + var.InsideWaterPoseStrength * 0.05 + clamp(var.WalkingStrength, 0, 1) * 2 * var.move_forward * var.MovingInsideWaterPoseStrength * 0.2 - var.BoatRidePoseStrength * torad(90) + cos(var.TurnPoseTimer) * var.TurnPoseStrength * 0.1 * abs(clamp(var.TurnDirection, -1, 0))",
					"var.llry": "var.SneakingLegPoseStrength * -0.1 - var.IdlePoseStrength * 0.1 - var.BoatRidePoseStrength * 0.1 - cos(var.TurnPoseTimer) * var.TurnPoseStrength * 0.4",
					"var.llrz": "var.IdlePoseStrength * -0.02 - abs(clamp(cos(var.WalkingTimerAbsolute), -1, 0)) * (var.BoatRidePoseStrength - var.IdleWatchingRX) * -0.2 * (1 / (clamp(var.AvgSpeed * 20, 0, 10) + 1))",
					"var.llty": "cos(var.WalkingRightTimer + cos(var.WalkingRightTimer * 2) * 0.1) * clamp(var.WalkingStrength, 0, 1 - var.SneakPoseStrength) * 3 * (1 - var.HopRunPoseStrength * 0.5) - var.HopRunPoseStrength - sin(clamp(var.IdlePoseTimer * 0.2 - 0.5, 0, torad(180))) * 0.5 * abs(clamp(cos(var.WalkingTimerAbsolute), 0, 1)) * if(var.IdlePose < 1, var.IdlePoseStrength, 1) - sin(clamp(var.SneakingTimer * 0.1 + torad(90), 0, torad(180))) * 2 * abs(clamp(cos(var.WalkingTimerAbsolute), 0, 1)) * if(var.SneakingPose < 1, var.SneakingPoseStrength, 1) + cos(var.InsideWaterTimer * 4) * var.InsideWaterPoseStrength * 0.5 - var.BoatRidePoseStrength * 0.75 - abs(clamp(cos(var.WalkingTimerAbsolute), -1, 0)) * (var.BoatRidePoseStrength - var.IdleWatchingRX * 0.25) * 3 * (1 / (clamp(var.AvgSpeed * 20, 0, 10) + 1)) + clamp(var.AvgSpeed, 0, 0.1) * var.BoatRidePoseStrength * 10 * var.move_strafing + clamp(sin(var.TurnPoseTimer) * var.TurnPoseStrength, -10, 0)",
					"var.lltx": "var.SneakingLegPoseStrength * 0.25",
					"var.lltz": "cos(var.WalkingRightTimer + 0.1 + cos(var.WalkingRightTimer * 2) * 0.1) * var.WalkingStrength - var.SneakingPoseStrength * 3 - abs(clamp(cos(var.WalkingTimerAbsolute), -1, 0)) * var.IdlePoseStrength * 0.15 - cos(var.IdleTimer * 0.1) * var.IdlePoseStrength * 0.25 + (var.BoatRidePoseStrength - var.IdleWatchingRX * 0.25) * 1 * (1 / (clamp(var.AvgSpeed * 20, 0, 10) + 1)) + var.BoatRidePoseStrength + abs(clamp(cos(var.WalkingTimerAbsolute), 0, 1)) * var.BoatRidePoseStrength * -4 * (1 / (clamp(var.AvgSpeed * 20, 0, 10) + 1))"
				},
				{
