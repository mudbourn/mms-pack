				    "var.sphs": "var.SwingPoseHeadStrength",
				    "var.splas": "if(var.SwingSide > 0, var.SwingPoseLeftArmStrength, var.SwingPoseRightArmStrength)",
				    "var.spras": "if(var.SwingSide > 0, var.SwingPoseRightArmStrength, var.SwingPoseLeftArmStrength)",
				    "var.splls": "if(var.SwingSide > 0, var.SwingPoseLeftLegStrength, var.SwingPoseRightLegStrength)",
				    "var.sprls": "if(var.SwingSide > 0, var.SwingPoseRightLegStrength, var.SwingPoseLeftLegStrength)",
				    "var.sprs": "var.SwingPoseRootStrength"
				},
				{
					"var.brx": "var.brx * var.spbs * var.allipbs + var.sbrx + var.allibrx",
					"var.bry": "var.bry * var.spbs * var.allipbs + var.sbry + var.allibry",
					"var.brz": "var.brz * var.spbs * var.allipbs + var.sbrz + var.allibrz",
					"var.btx": "var.btx * var.spbs * var.allipbs + var.sbtx + var.allibtx",
					"var.bty": "var.bty * var.spbs * var.allipbs + var.sbty + var.allibty",
					"var.btz": "var.btz * var.spbs * var.allipbs + var.sbtz + var.allibtz",
					"var.hrx": "var.hrx * var.sphs * var.alliphs + var.shrx + var.allihrx",
					"var.hry": "var.hry * var.sphs * var.alliphs + var.shry + var.allihry",
					"var.hrz": "var.hrz * var.sphs * var.alliphs + var.shrz + var.allihrz",
					"var.htx": "var.htx * var.sphs * var.alliphs + var.shtx + var.allihtx",
					"var.hty": "var.hty * var.sphs * var.alliphs + var.shty + var.allihty",
					"var.htz": "var.htz * var.sphs * var.alliphs + var.shtz + var.allihtz",
					"var.larx": "var.larx * var.splas * var.alliplas + var.slarx + var.allilarx",
					"var.lary": "var.lary * var.splas * var.alliplas + var.slary + var.allilary",
					"var.larz": "var.larz * var.splas * var.alliplas + var.slarz + var.allilarz",
					"var.latx": "var.latx * var.splas * var.alliplas + var.slatx + var.allilatx",
					"var.laty": "var.laty * var.splas * var.alliplas + var.slaty + var.allilaty",
					"var.latz": "var.latz * var.splas * var.alliplas + var.slatz + var.allilatz",
					"var.rarx": "var.rarx * var.spras * var.allipras + var.srarx + var.allirarx",
					"var.rary": "var.rary * var.spras * var.allipras + var.srary + var.allirary",
					"var.rarz": "var.rarz * var.spras * var.allipras + var.srarz + var.allirarz",
					"var.ratx": "var.ratx * var.spras * var.allipras + var.sratx + var.alliratx",
					"var.raty": "var.raty * var.spras * var.allipras + var.sraty + var.alliraty",
					"var.ratz": "var.ratz * var.spras * var.allipras + var.sratz + var.alliratz",
					"var.llrx": "var.llrx * var.splls * var.alliplls + var.sllrx + var.allillrx",
					"var.llry": "var.llry * var.splls * var.alliplls + var.sllry + var.allillry",
					"var.llrz": "var.llrz * var.splls * var.alliplls + var.sllrz + var.allillrz",
					"var.lltx": "var.lltx * var.splls * var.alliplls + var.slltx + var.allilltx",
					"var.llty": "var.llty * var.splls * var.alliplls + var.sllty + var.allillty",
					"var.lltz": "var.lltz * var.splls * var.alliplls + var.slltz + var.allilltz",
					"var.rlrx": "var.rlrx * var.sprls * var.alliprls + var.srlrx + var.allirlrx",
					"var.rlry": "var.rlry * var.sprls * var.alliprls + var.srlry + var.allirlry",
					"var.rlrz": "var.rlrz * var.sprls * var.alliprls + var.srlrz + var.allirlrz",
					"var.rltx": "var.rltx * var.sprls * var.alliprls + var.srltx + var.allirltx",
					"var.rlty": "var.rlty * var.sprls * var.alliprls + var.srlty + var.allirlty",
					"var.rltz": "var.rltz * var.sprls * var.alliprls + var.srltz + var.allirltz",
					"var.rrx": "var.rrx * var.sprs * var.alliprs + var.srrx + var.allirrx",
					"var.rry": "var.rry * var.sprs * var.alliprs + var.srry + var.allirry",
					"var.rrz": "var.rrz * var.sprs * var.alliprs + var.srrz + var.allirrz",
					"var.rtx": "var.rtx * var.sprs * var.alliprs + var.srtx + var.allirtx",
					"var.rty": "var.rty * var.sprs * var.alliprs + var.srty + var.allirty",
					"var.rtz": "var.rtz * var.sprs * var.alliprs + var.srtz + var.allirtz"
				},
				{
					"body.rx": "var.brx",
					"body.ry": "var.bry * cos(var.brx) + var.brz * sin(var.brx)",
					"body.rz": "var.brz * cos(var.brx) + var.bry * sin(var.brx)",
					"body.tx": "var.btx + sin(var.brz) * 11",
					"body.ty": "22 + var.bty - cos(var.brx) * 11 - cos(var.brz) * 11",
					"body.tz": "var.btz - sin(var.brx) * 11",
					"head.rx": "var.hrx",
					"head.ry": "var.hry",
					"head.rz": "var.hrz",
					"head.tx": "body.tx + var.htx",
					"head.ty": "body.ty + var.hty",
					"head.tz": "body.tz + var.htz",
					"right_arm.rx": "if(is_first_person_hand && !is_in_gui, right_arm.rx, var.rarx)",
					"right_arm.ry": "if(is_first_person_hand && !is_in_gui, right_arm.ry, var.rary)",
					"right_arm.rz": "if(is_first_person_hand && !is_in_gui, right_arm.rz, var.rarz + abs(body.rz) * (1 - var.DisableParentedLimbs) * 0.5)",
					"right_arm.tx": "if(is_first_person_hand && !is_in_gui, right_arm.tx, var.DisableParentedLimbs * -5 + (body.tx - 5 * cos(var.bry)) * (1 - var.DisableParentedLimbs) + var.ratx + abs(body.rz) * (1 - var.DisableParentedLimbs))",
					"right_arm.ty": "if(is_first_person_hand && !is_in_gui, right_arm.ty, body.ty * (1 - var.DisableParentedLimbs) + 2.5 + var.raty)",
					"right_arm.tz": "if(is_first_person_hand && !is_in_gui, right_arm.tz, (body.tz + sin(var.bry) * 5) * (1 - var.DisableParentedLimbs) + var.ratz)",
					"left_arm.rx": "if(is_first_person_hand && !is_in_gui, left_arm.rx, var.larx)",
					"left_arm.ry": "if(is_first_person_hand && !is_in_gui, left_arm.ry, var.lary)",
					"left_arm.rz": "if(is_first_person_hand && !is_in_gui, left_arm.rz, var.larz - abs(body.rz) * (1 - var.DisableParentedLimbs) * 0.5)",
					"left_arm.tx": "if(is_first_person_hand && !is_in_gui, left_arm.tx, var.DisableParentedLimbs * 5 + (body.tx + 5 * cos(var.bry)) * (1 - var.DisableParentedLimbs) + var.latx - abs(body.rz) * (1 - var.DisableParentedLimbs))",
					"left_arm.ty": "if(is_first_person_hand && !is_in_gui, left_arm.ty, body.ty * (1 - var.DisableParentedLimbs) + 2.5 + var.laty)",
					"left_arm.tz": "if(is_first_person_hand && !is_in_gui, left_arm.tz, (body.tz - sin(var.bry) * 5) * (1 - var.DisableParentedLimbs) + var.latz)",
					"right_leg.rx": "if(var.is_riding > 0, torad(-81), var.rlrx + (-sin(var.bry) * 0.5 - var.btz * 0.08 - clamp(var.rlty * 1, -5, 0) * 0.1) * (1 - var.DisableParentedLimbs))",
					"right_leg.ry": "if(var.is_riding > 0, torad(18), var.rlry - var.rltry)",
					"right_leg.rz": "if(var.is_riding > 0, torad(4.5), var.rlrz + var.btx * 0.08 * (1 - var.DisableParentedLimbs))",
					"right_leg.tx": "if(var.is_riding > 0, -2, -2 + var.rltx + var.btx * (1 - var.DisableParentedLimbs))",
					"right_leg.ty": "if(var.is_riding > 0, 12, 12 + if(var.is_on_ground > 0, clamp(var.rlty, -100, 0), var.rlty))",
					"right_leg.tz": "if(var.is_riding > 0, 0, var.rltz + (clamp(var.rlty * 1, -5, 0) + sin(var.bry) * 5 + var.btz) * (1 - var.DisableParentedLimbs))",
					"left_leg.rx": "if(var.is_riding > 0, torad(-81), var.llrx + (sin(var.bry) * 0.5 - var.btz * 0.08 - clamp(var.llty * 1, -5, 0) * 0.1) * (1 - var.DisableParentedLimbs))",
					"left_leg.ry": "if(var.is_riding > 0, torad(-18), var.llry - var.lltry)",
					"left_leg.rz": "if(var.is_riding > 0, torad(-4.5), var.llrz + var.btx * 0.08 * (1 - var.DisableParentedLimbs))",
					"left_leg.tx": "if(var.is_riding > 0, 2, 2 + var.lltx + var.btx * (1 - var.DisableParentedLimbs))",
					"left_leg.ty": "if(var.is_riding > 0, 12, 12 + if(var.is_on_ground > 0, clamp(var.llty, -100, 0), var.llty))",
					"left_leg.tz": "if(var.is_riding > 0, 0, var.lltz + (clamp(var.llty * 1, -5, 0) - sin(var.bry) * 5 + var.btz) * (1 - var.DisableParentedLimbs))",
					"var.prrx": "var.rrx",
				    "var.prry": "var.rry * (1 - var.DisableParentedLimbs)",
				    "var.prtx": "var.rtx",
				    "var.prty": "var.rty - if(is_sneaking, 2, 0) - 0.1",
				    "var.prtz": "var.rtz + if(is_crawling, 2, 0)",
					"root.rx": "if(var.NewFrame > 0, var.prrx, 0)",
					"root.ry": "if(var.NewFrame > 0, var.prry, 0)",
					"root.tx": "if(var.NewFrame > 0, var.prtx, 0)",
					"root.ty": "if(var.NewFrame > 0, var.prty, 0)",
					"root.tz": "if(var.NewFrame > 0, var.prtz, 0)"
				},
				{
					"var.cbrx": "body.rx",
					"var.cbry": "body.ry",
					"var.cbrz": "body.rz",
					"var.cbtx": "body.tx",
					"var.cbty": "body.ty",
					"var.cbtz": "body.tz"
				},
				{
					"var.LastHead_Yaw": "if(var.NewFrame > 0, head_yaw, var.LastHead_Yaw)",
					"var.LastHead_Pitch": "if(var.NewFrame > 0, head_pitch, var.LastHead_Pitch)",
					"var.LastVelocityYJump": "if(var.NewFrame > 0, var.VelocityYJump, var.LastVelocityYJump)",
					"var.LastVelocityY": "if(var.NewFrame > 0, var.VelocityY, var.LastVelocityY)",
					"var.LastAvgVelocityY": "if(var.NewFrame > 0, var.AvgVelocityY, var.LastAvgVelocityY)",
					"var.LastWalkingStrength": "if(var.NewFrame > 0, var.WalkingStrength, var.LastWalkingStrength)",
					"var.LastSneakingPoseStrength": "if(var.NewFrame > 0, var.SneakingPoseStrength, var.LastSneakingPoseStrength)",
					"var.LastHeadTurningPose": "if(var.NewFrame > 0, var.HeadTurningPose, var.LastHeadTurningPose)",
					"var.LastFallingPose": "if(var.NewFrame > 0, var.FallingPose, var.LastFallingPose)",
					"var.LastSwingProgress": "if(var.NewFrame > 0, var.SwingProgress, var.LastSwingProgress)",
					"var.LastAge": "if(var.NewFrame > 0, var.Age, var.LastAge)",
					"var.LastPosY": "if(var.NewFrame > 0, pos_y, var.LastPosY)",
					"var.LastPosZ": "if(var.NewFrame > 0, pos_z, var.LastPosZ)",
					"var.LastPosX": "if(var.NewFrame > 0, pos_x, var.LastPosX)",
					"var.LastRotY": "if(var.NewFrame > 0, rot_y, var.LastRotY)",
					"var.LastRotX": "if(var.NewFrame > 0, rot_x, var.LastRotX)",
					"var.LastHeightAboveGround": "if(var.NewFrame > 0, var.HeightAboveGround, var.LastHeightAboveGround)",
					"var.LastFrameCount": "frame_counter"
				}
			]
		},
